{
  "name": "Project_Muse",
  "version": "1.0.0",
  "description": "Node Garden — creative coding with Three.js WebGPU",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint src/ tests/",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "dependencies": {
    "lil-gui": "^0.21.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/three": "^0.183.1",
    "@vitest/coverage-v8": "^4.1.2",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint",
      "oxfmt --write"
    ],
    "*.{json,md,html,css}": [
      "oxfmt --write"
    ]
  }
}
